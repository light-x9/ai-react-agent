# ============================================
# 环境变量配置（复制为 .env 后填入真实值）
# ============================================
# 部署步骤:
#   cp .env.example .env
#   vim .env     # 填入真实密钥
# ============================================

# 必填：通义千问 SDK
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# 必填：JWT 密钥（至少 32 字节随机字符串，生成命令：openssl rand -base64 48）
JWT_SECRET=change-me-please-use-openssl-rand-base64-48

# 必填：Google 搜索（https://serper.dev）
SERPER_API_KEY=xxxxxxxxxxxxxxxx

# 可选：高德地图（https://console.amap.com/）
AMAP_API_KEY=xxxxxxxxxxxxxxxx

# 可选：Pexels 图片搜索（https://www.pexels.com/api/）
PEXELS_API_KEY=xxxxxxxxxxxxxxxx

# 数据库密码（和 setup-pgvector.sh 里保持一致）
PG_PASSWORD=your_db_password_here

# Spring 配置
SPRING_PROFILES_ACTIVE=prod
